{
  "expo": {
    "name": "trave-social",
    "slug": "trave-social",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trave-social",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "package": "com.tauhee56.travesocial",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "SET_GOOGLE_MAPS_API_KEY_IN_BUILD_ENV"
        }
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tauhee56.travesocial",
      "buildNumber": "1.0.7",
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "googleMapsApiKey": "SET_GOOGLE_MAPS_API_KEY_IN_BUILD_ENV"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow Trave-Social to access your camera for posting photos and live streaming.",
        "NSMicrophoneUsageDescription": "Allow Trave-Social to access your microphone for live streaming.",
        "NSPhotoLibraryUsageDescription": "Allow Trave-Social to access your photos for posting.",
        "NSLocationWhenInUseUsageDescription": "Allow Trave-Social to use your location for map features and location tagging.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow Trave-Social to track your travels to create passport stamps.",
        "NSLocationAlwaysUsageDescription": "Allow Trave-Social to track your travels even when the app is closed to create passport stamps."
      },
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "./plugins/withCleartextTraffic.js",
      "./plugins/withNetworkSecurityConfig.js",
      "./plugins/withAppAuthRedirectScheme.js",
      "./plugins/withAndroidManifestFix.js",
      "./plugins/withAndroidPip.js",
      "./plugins/withKotlinVersionFix.js",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "dynamic"
          },
          "android": {
            "manifestPlaceholders": {
              "appAuthRedirectScheme": "trave-social",
              "traveSocialScheme": "trave-social"
            },
            "enableProguardInReleaseBuilds": false,
            "enableShrinkResourcesInReleaseBuilds": false,
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "kotlinVersion": "1.9.24",
            "enableMinifyInReleaseBuilds": false,
            "extraMavenRepos": [
              "https://www.jitpack.io"
            ],
            "gradleProperties": {
              "org.gradle.internal.http.connectionTimeout": "180000",
              "org.gradle.internal.http.socketTimeout": "180000",
              "org.gradle.internal.repository.max.retries": "10"
            }
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera for posting photos and live streaming.",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for live streaming.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos for posting.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera for taking photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to track your travels to create passport stamps.",
          "locationAlwaysPermission": "Allow $(PRODUCT_NAME) to track your travels even when the app is closed to create passport stamps.",
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location for map features and location tagging.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#667eea"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "costMode": true,
      "analyticsEnabled": true,
      "dailyCounterSampleRate": 0.05,
      "GOOGLE_MAP_API_KEY": "SET_IN_ENV",
      "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "SET_IN_ENV",
      "FIREBASE_API_KEY": "",
      "FIREBASE_AUTH_DOMAIN": "travel-app-3da72.firebaseapp.com",
      "FIREBASE_PROJECT_ID": "travel-app-3da72",
      "FIREBASE_STORAGE_BUCKET": "travel-app-3da72.firebasestorage.app",
      "FIREBASE_MESSAGING_SENDER_ID": "709095117662",
      "FIREBASE_APP_ID": "1:709095117662:web:5f00f45bb4e392ee17f5cf",
      "FIREBASE_MEASUREMENT_ID": "G-PFZRL4FDFD",
      "eas": {
        "projectId": "acd24cff-c209-4589-86fa-508a00859191"
      }
    },
    "owner": "tauheeddev56"
  }
}